SearchService
public List<ProfileSearchResponse> searchProfiles(SearchRequest request) {

    if (!hasSearchCondition(request)) {
        throw new IllegalArgumentException("検索条件を1つ以上指定してください");
    }

    return searchRepository.searchProfiles(request);
}

private boolean hasSearchCondition(SearchRequest request) {
    return hasText(request.getKeyword())
            || hasText(request.getSkillName())
            || hasText(request.getDivisionName())
            || hasText(request.getProjectName())
            || request.getMinYears() != null
            || request.isCurrentProjectOnly();
}

private boolean hasText(String value) {
    return value != null && !value.isBlank();
}


Controller

@PostMapping("/profiles")
public ResponseEntity<?> searchProfiles(@RequestBody SearchRequest request) {
    try {
        List<ProfileSearchResponse> results =
                searchService.searchProfiles(request);

        if (results.isEmpty()) {
            return ResponseEntity
                    .status(HttpStatus.BAD_REQUEST)
                    .body(Map.of("message", "検索結果がありませんでした"));
        }

        return ResponseEntity.ok(results);

    } catch (IllegalArgumentException e) {
        return ResponseEntity
                .status(HttpStatus.BAD_REQUEST)
                .body(Map.of("message", e.getMessage()));
    }
}


