# =========================================
# Profile
# =========================================

# プロフィール取得

curl http://localhost:8080/api/profile/A001

# response
{
  "hrid":"A001",
  "name":"田中太郎",
  "mailAddress":"tanaka@example.com",
  "rankName":"Senior Engineer",
  "free":"バックエンド好き",
  "careers":[
    {
      "careerId":1,
      "projectId":1,
      "projectName":"Trading System",
      "projectContent":"Core trading platform development",
      "startTime":"2023-04-01",
      "endTime":null,
      "skillNames":[
        "Java",
        "Spring Boot"
      ]
    }
  ]
}


# =========================================
# プロフィール更新
# =========================================

curl -X PUT http://localhost:8080/api/profile/A001 \
  -H "Content-Type: application/json" \
  -d '{
    "name":"田中太郎",
    "mailAddress":"tanaka@example.com",
    "free":"機械学習とバックエンドが好き"
  }'

# response
{
  "message":"プロフィール更新成功"
}


