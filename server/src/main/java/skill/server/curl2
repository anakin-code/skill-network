# =========================================
# キャリア登録
# =========================================

curl -X POST http://localhost:8080/api/career \
  -H "Content-Type: application/json" \
  -d '{
    "hrid":"A001",
    "projectId":1,
    "startTime":"2024-04-01",
    "endTime":null,
    "skillIds":[1,2]
  }'

# response
{
  "careerId":10,
  "projectId":1,
  "projectName":"Trading System",
  "projectContent":"Core trading platform development",
  "startTime":"2024-04-01",
  "endTime":null,
  "skillNames":[
    "Java",
    "Spring Boot"
  ]
}


# =========================================
# キャリア更新
# =========================================

curl -X PUT http://localhost:8080/api/career/4 \
  -H "Content-Type: application/json" \
  -d '{
    "projectId":1,
    "startTime":"2024-04-01",
    "endTime":null,
    "skillIds":[1,2,7]
  }'

# response
{
  "careerId":4,
  "projectId":1,
  "projectName":"Trading System",
  "projectContent":"Core trading platform development",
  "startTime":"2024-04-01",
  "endTime":null,
  "skillNames":[
    "Java",
    "Spring Boot",
    "React"
  ]
}


